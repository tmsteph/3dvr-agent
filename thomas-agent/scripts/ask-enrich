#!/usr/bin/env bash
FILE="$HOME/3dvr-agent/thomas-agent/leads.csv"

tmp="$FILE.tmp"
echo "name,link,contact,status,date" > "$tmp"

tail -n +2 "$FILE" | while IFS=, read -r name link status date; do
  contact=""

  if [ -n "$link" ]; then
    html=$(curl -L -s "$link")

    path=$(echo "$html" | grep -oiE 'href="[^"]*(contact|about)[^"]*"' | head -n1 | sed 's/href="//;s/"//')

    if [ -n "$path" ]; then
      if echo "$path" | grep -q '^http'; then
        contact="$path"
      else
        contact="$link$path"
      fi
    fi

    if [ -z "$contact" ]; then
      contact=$(echo "$html" | grep -oiE 'mailto:[^"]+' | head -n1)
    fi
  fi

  echo "$name,$link,$contact,$status,$date" >> "$tmp"
done

mv "$tmp" "$FILE"
echo "Enriched leads with full contact links"
