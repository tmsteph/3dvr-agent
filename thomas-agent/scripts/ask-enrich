#!/data/data/com.termux/files/usr/bin/bash
FILE="$HOME/3dvr-agent/thomas-agent/leads.csv"

tmp="$FILE.tmp"
echo "name,link,contact,status,date" > "$tmp"

tail -n +2 "$FILE" | while IFS=, read -r name link contact status date; do
  newcontact="$contact"

  if [ -n "$link" ]; then
    html="$(curl -L -s "$link")"
    path="$(echo "$html" | grep -oiE 'href="[^"]*(contact|about)[^"]*"' | head -n1 | sed 's/href="//;s/"//')"

    if [ -n "$path" ]; then
      if echo "$path" | grep -q '^http'; then
        newcontact="$path"
      elif echo "$path" | grep -q '^/'; then
        newcontact="${link%/}$path"
      else
        newcontact="${link%/}/$path"
      fi
    fi

    if [ -z "$newcontact" ]; then
      newcontact="$(echo "$html" | grep -oiE 'mailto:[^"]+' | head -n1)"
    fi
  fi

  echo "$name,$link,$newcontact,$status,$date" >> "$tmp"
done

mv "$tmp" "$FILE"
echo "Enriched leads with full contact links"
