#!/data/data/com.termux/files/usr/bin/bash
case "${1:-a}" in
  a)
    echo 'Hey—I took a quick look at your site and had a couple small ideas that could make it clearer/easier to use. Want me to share?'
    ;;
  b)
    echo 'Hey, I was checking out your site and noticed a couple easy improvements. Want me to send them over?'
    ;;
  c)
    echo 'Hey—I had a quick idea for your website that could help customers take action faster. Want me to share?'
    ;;
  *)
    echo "Usage: ask-message [a|b|c]"
    ;;
esac
