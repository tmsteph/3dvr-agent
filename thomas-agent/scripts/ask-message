#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
FILE="${THREEDVR_LEADS_FILE:-$ROOT/leads.csv}"
LAUNCH_URL="https://3dvr.tech/launch-in-3-days.html"
mode="${1:-a}"
target="$2"

get_lead() {
  [ -f "$FILE" ] || return 1
  awk -F, -v name="$target" 'NR>1 && $1==name {print; exit}' "$FILE"
}

msg_a() {
  echo 'Hey—I took a quick look at your site and noticed one small thing in the customer flow that might be worth tightening. Want me to send a quick note?'
}

msg_b() {
  echo 'Hey, I was checking out your site and had one practical mobile/customer-flow note. Nothing huge, but it looked worth sharing. Want me to send it over?'
}

msg_c() {
  echo 'Hey—I had a quick idea for making one part of your site easier for customers to act on. Want me to share?'
}

msg_offer() {
  echo "I help small service businesses get clearer online, follow up faster, and launch useful improvements without getting buried in tools. The quick entry point is Launch in 3 Days at \$20/month; active businesses usually fit Builder at \$50/month. Context: $LAUNCH_URL"
}

msg_lead() {
  line="$(get_lead)"
  if [ -n "$line" ]; then
    name="$(printf '%s' "$line" | awk -F, '{print $1}')"
    link="$(printf '%s' "$line" | awk -F, '{print $2}')"
    echo "Hey—I took a quick look at ${name}'s site (${link}) and saw a couple ways it could be clearer and easier for customers to act on. Want me to share?"
  else
    msg_a
  fi
}

msg_smart() {
  line="$(get_lead)"
  if [ -z "$line" ]; then
    msg_a
    return
  fi

  name="$(printf '%s' "$line" | awk -F, '{print $1}')"
  link="$(printf '%s' "$line" | awk -F, '{print $2}')"
  contact="$(printf '%s' "$line" | awk -F, '{print $3}')"
  haystack="$(printf '%s %s %s' "$name" "$link" "$contact" | tr '[:upper:]' '[:lower:]')"

  case "$haystack" in
    *menu*|*restaurant*|*cafe*|*coffee*|*food*|*bar*|*grill*)
      echo "Hey—I took a quick look at the ${name} site and noticed one small menu/contact-flow thing that might be worth tightening on mobile. Want me to send a quick note?"
      ;;
    *shop*|*store*|*product*|*cart*|*checkout*)
      echo "Hey—I took a quick look at the ${name} site and noticed one small browse/buy flow thing that might be worth tightening. Want me to share?"
      ;;
    *book*|*appointment*|*schedule*|*booking*)
      echo "Hey—I took a quick look at the ${name} site and noticed one small booking/contact flow thing that could be clearer. Want me to send a quick note?"
      ;;
    *law*|*legal*|*attorney*|*dental*|*clinic*|*health*|*realestate*|*mortgage*)
      echo "Hey—I took a quick look at the ${name} site and noticed one small trust/contact-flow thing that might be worth tightening. Want me to share?"
      ;;
    *)
      echo "Hey—I took a quick look at the ${name} site (${link}) and noticed one small customer-flow thing that might be worth tightening. Want me to share?"
      ;;
  esac
}

case "$mode" in
  a) msg_a ;;
  b) msg_b ;;
  c) msg_c ;;
  offer) msg_offer ;;
  lead|personal) msg_lead ;;
  smart) msg_smart ;;
  *)
    echo 'Usage: ask-message [a|b|c|offer|lead|smart] "Business Name"'
    ;;
esac
