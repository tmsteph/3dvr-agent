#!/usr/bin/env bash
source "$HOME/3dvr-agent/thomas-agent/scripts/lib/platform.sh"
FILE="$HOME/3dvr-agent/thomas-agent/leads.csv"
LAUNCH_URL="https://3dvr.tech/launch-in-3-days.html"

line="$(awk -F, 'NR>1 && $4=="new" && ($2!="" || $3!="") {print; exit}' "$FILE")"

if [ -z "$line" ]; then
  echo "No usable new leads."
  echo
  echo "Run:"
  echo "ask-crawl && ask-enrich && ask-track new"
  exit 0
fi

name="$(printf '%s' "$line" | awk -F, '{print $1}')"
link="$(printf '%s' "$line" | awk -F, '{print $2}')"
contact="$(printf '%s' "$line" | awk -F, '{print $3}')"

target="$contact"
[ -z "$target" ] && target="$link"

echo "NEXT LEAD"
echo "Name: $name"
echo "Site: $link"
echo "Contact: $contact"
echo
echo "STEP 1: Open this page"
echo "open_url \"$target\""
echo
echo "STEP 2: Send this opener"
bash "$HOME/3dvr-agent/thomas-agent/scripts/ask-personalize" "$name" "$link" "$contact"
echo
echo "STEP 3: If they want context, send this"
ask-message offer
echo
echo "Landing page: $LAUNCH_URL"
echo
echo "STEP 4: To open/copy/send from the CLI, run this"
echo "ask-send \"$name\""
echo
echo "STEP 5: After sending manually, run this"
echo "ask-track contact \"$name\""
echo
echo "STEP 6: Then get the next lead"
echo "ask-next"
echo
echo "Opening page now..."
open_url "$target"
