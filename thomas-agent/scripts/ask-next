#!/data/data/com.termux/files/usr/bin/bash
FILE="$HOME/3dvr-agent/thomas-agent/leads.csv"
line="$(awk -F, 'NR>1 && $4=="new" {print; exit}' "$FILE")"
if [ -z "$line" ]; then
  echo "No new leads."
  exit 0
fi
name="$(printf '%s' "$line" | awk -F, '{print $1}')"
link="$(printf '%s' "$line" | awk -F, '{print $2}')"
contact="$(printf '%s' "$line" | awk -F, '{print $3}')"
echo "Name: $name"
echo "Site: $link"
echo "Contact: $contact"
echo
echo 'Message:'
echo 'Hey, I checked your site and saw a few quick wins—I fix websites for $20/month. Want me to take a look?'
echo
echo "Open site:"
echo "termux-open-url \"${contact:-$link}\""
echo
echo "After sending:"
echo "ask-track contact \"$name\""
