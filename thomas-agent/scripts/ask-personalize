#!/usr/bin/env bash
name="$1"
site="$2"
contact="$3"

hint="site"

case "$site $contact" in
  *menu*|*Menu*) hint="menu or contact flow" ;;
  *book*|*reserv*|*order*) hint="booking or ordering flow" ;;
  *contact*|*about*) hint="contact flow" ;;
  *event*|*cater*) hint="events or catering flow" ;;
esac

echo "Hey—I took a quick look at the $name site and noticed one small $hint thing that might be worth tightening for customers. Want me to send a quick note?"
