#!/usr/bin/env bash

echo "== 3dvr run =="
echo

echo "[1/3] Crawl step..."
ask-crawl || true
echo

echo "[2/3] Enrich step..."
if [ -f "$HOME/3dvr-agent/thomas-agent/leads.csv" ]; then
  ask-enrich || true
else
  echo "No leads file yet, skipping enrich."
fi
echo

echo "[3/3] Next lead..."
ask-next || exit 1
