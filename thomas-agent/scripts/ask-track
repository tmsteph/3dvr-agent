#!/usr/bin/env bash
FILE="$HOME/3dvr-agent/thomas-agent/leads.csv"

status="$1"
shift
name="$*"

if [ -z "$status" ] || [ -z "$name" ]; then
  echo 'Usage: ask-track [new|contacted|replied|closed] "Business Name"'
  exit 1
fi

case "$status" in
  new|contacted|replied|closed) ;;
  *)
    echo 'Status must be one of: new, contacted, replied, closed'
    exit 1
    ;;
esac

tmp="$FILE.tmp"
awk -F, -v OFS=, -v target="$name" -v status="$status" '
NR==1 { print; next }
$1==target { $4=status }
{ print }
' "$FILE" > "$tmp" && mv "$tmp" "$FILE"

echo "Updated: $name -> $status"
